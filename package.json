{
  "name": "pikabu-pic-collector",
  "version": "2.0.0",
  "description": "Telegram bot for collecting Pikabu posts by tags and authors",
  "main": "src/main.ts",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch run src/main.ts",
