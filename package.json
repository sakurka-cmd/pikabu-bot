    "db:push": "prisma db push"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "node-telegram-bot-api": "^0.67.0",
    "@prisma/client": "5"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "prisma": "5",
    "typescript": "^5"
  }
}
